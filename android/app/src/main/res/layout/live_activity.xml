<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/live_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pulse Focus"
                android:textColor="@color/pulse_live_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/live_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Pomodoro"
                android:textColor="@color/pulse_live_subtitle"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/live_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Focusing"
                android:textColor="@color/pulse_live_status"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Plain text only — Chronometer counted past 0 into negative times. -->
        <TextView
            android:id="@+id/live_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="25:00"
            android:textColor="@color/pulse_live_timer"
            android:textSize="26sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/live_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/live_btn_primary"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/pulse_live_btn_secondary"
            android:text="Pause"
            android:textColor="@color/pulse_live_title"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/live_btn_finish"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:background="@drawable/pulse_live_btn_primary"
            android:text="Finish"
            android:textColor="#0E0F0C"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
